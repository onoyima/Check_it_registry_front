{
  "name": "checkit-tests",
  "version": "1.0.0",
  "description": "Test suite for Check It Device Registry",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:api": "jest tests/api",
    "test:services": "jest tests/services",
    "test:integration": "jest tests/integration",
    "test:mobile": "jest tests/services/mobile-integration.test.js",
    "test:security": "jest tests/services/security-analysis.test.js",
    "test:admin": "jest tests/api/admin-system.test.js",
    "test:recovery": "jest tests/api/recovery-services.test.js",
    "test:device": "jest tests/api/device-management.test.js",
    "test:workflow": "jest tests/integration/device-workflow.test.js"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": ["<rootDir>/setup.js"],
    "collectCoverageFrom": [
      "../server/**/*.js",
      "../src/**/*.{js,ts,tsx}",
      "!../server/node_modules/**",
      "!../src/node_modules/**",
      "!../server/config/database.js",
      "!../server/app.js"
    ],
    "coverageReporters": ["text", "lcov", "html"],
    "coverageDirectory": "coverage",
    "testMatch": [
      "**/__tests__/**/*.(js|ts)",
      "**/*.(test|spec).(js|ts)"
    ],
    "moduleFileExtensions": ["js", "ts", "tsx", "json"],
    "transform": {
      "^.+\\.(js|ts|tsx)$": "babel-jest"
    },
    "testTimeout": 30000,
    "verbose": true
  },
  "devDependencies": {
    "@babel/core": "^7.22.0",
    "@babel/preset-env": "^7.22.0",
    "@babel/preset-typescript": "^7.22.0",
    "babel-jest": "^29.5.0",
    "jest": "^29.5.0",
    "supertest": "^6.3.0",
    "mysql2": "^3.6.0"
  }
}